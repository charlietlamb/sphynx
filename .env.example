DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/sphynx
# Max query-pool connections (default 20). Raise on a container that fans out
# many concurrent webhook projections + reads; keep under the DB's own limit.
#DATABASE_POOL_MAX=20
# Connection for LISTEN/NOTIFY (SSE freshness). Defaults to DATABASE_URL. A
# pooler (Neon's PgBouncer "-pooler" endpoint) silently drops LISTEN/NOTIFY, so
# in prod point this at the DIRECT (non-pooled) endpoint.
#LISTEN_DATABASE_URL=

BETTER_AUTH_SECRET=development-only-secret-change-before-production
BETTER_AUTH_URL=http://127.0.0.1:3003
AUTH_SERVER_URL=http://127.0.0.1:3003
AUTH_TRUSTED_ORIGINS=http://localhost:3006,http://127.0.0.1:3006

HOST=127.0.0.1
PORT=3003

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITHUB_WEBHOOK_SECRET=

NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-static-domain.ngrok-free.app

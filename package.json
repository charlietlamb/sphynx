{
  "name": "sphynx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@base-ui/react": "1.5.0",
    "@pierre/diffs": "1.2.12",
    "@better-auth/drizzle-adapter": "1.6.13",
    "@biomejs/biome": "2.4.16",
    "@effect/platform": "0.96.1",
    "@effect/platform-bun": "0.89.0",
    "@fontsource-variable/fraunces": "5.2.9",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@phosphor-icons/react": "2.1.10",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/react-table": "8.21.3",
    "@types/bun": "latest",
    "@types/node": "25.5.0",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.4",
    "better-auth": "1.6.13",
    "nitro": "3.0.260603-beta",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "drizzle-kit": "0.31.8",
    "drizzle-orm": "0.45.2",
    "effect": "3.21.2",
    "husky": "^9.1.7",
    "knip": "6.15.0",
    "next-themes": "0.4.6",
    "nuqs": "2.9.0",
    "pg": "8.16.3",
    "react": "19.2.4",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.2.1",
    "turbo": "^2.8.17",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "ultracite": "7.8.1",
    "vite": "7.1.12"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "start": "bun --cwd apps/web start",
    "start:server": "bun --cwd apps/server start",
    "typecheck": "turbo run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "knip": "knip --no-config-hints",
    "doctor": "react-doctor --yes",
    "test": "turbo run test",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && bun run db:setup",
    "db:setup": "bun run db:up && bun run db:migrate",
    "db:generate": "bun --cwd packages/db db:generate",
    "db:migrate": "bun --cwd packages/db db:migrate",
    "db:studio": "bun --cwd packages/db db:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "react-doctor": "^0.7.7",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "ultracite": "catalog:"
  },
  "description": "Code review platform.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charlietlamb/sphynx.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/charlietlamb/sphynx/issues"
  },
  "homepage": "https://github.com/charlietlamb/sphynx#readme"
}
